FLASK_ENV=development
SECRET_KEY=replace-this-in-production
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH_MB=16


M4_EMBEDDING_MODEL_PATH=model_weights/m4_embedding/all-MiniLM-L6-v2
M4_DEVICE=cpu

M4_REQUEST_TIMEOUT=6
M4_REQUEST_SLEEP=0.05
M4_MAX_SECONDS=26

M4_SOURCE_LIMIT=6
M4_CANDIDATE_LIMIT=25
M4_QUERY_VARIANTS_LIMIT=2

M4_USE_SPECIES_FILTER=1
M4_FALLBACK_TO_ORIGINAL_QUERY=0

M4_INCLUDE_SEMANTIC_SCHOLAR=1
M4_INCLUDE_OPENALEX=1
M4_INCLUDE_CROSSREF=1
M4_INCLUDE_EUROPEPMC=1
M4_INCLUDE_PUBMED=1
M4_INCLUDE_GBIF=1
M4_INCLUDE_INATURALIST=1
M4_INCLUDE_ADW=1
M4_INCLUDE_BHL=1
M4_INCLUDE_ARXIV=0

M4_BM25_WEIGHT=0.34
M4_EMBEDDING_WEIGHT=0.34
M4_SPECIES_MATCH_WEIGHT=0.22
M4_SOURCE_QUALITY_WEIGHT=0.10


M5_TOP_K=5
M5_QUERY_WEIGHT=0.70
M5_M4_SCORE_WEIGHT=0.20
M5_CONTEXT_MATCH_WEIGHT=0.10

M6_OLLAMA_MODEL=llama3
M6_OUTPUT_LANGUAGE=Traditional Chinese
M6_USE_ADW=1
M6_MAX_DOCUMENTS=5
M6_MAX_ABSTRACT_CHARS=1200